---
description: ALWAYS use when writing or modifying code comments and documentation to ensure clarity and maintainability. This rule enforces standards for Java Doc, inline comments, and documentation best practices across the codebase.
globs: "**/*.java"
alwaysApply: false
---
<?xml version="1.0" encoding="UTF-8"?>
<cursor_rules>
    <rule>
        <name>code_comments</name>
        <description>Padrões para escrita e manutenção de comentários e documentação em código Java</description>
        
        <filters>
            <filter>
                <type>file_extension</type>
                <pattern>\.java$</pattern>
            </filter>
            <filter>
                <type>content</type>
                <pattern>(?s)/\*\*.*?\*/</pattern>
            </filter>
        </filters>

        <guidelines>
            <section name="general_comments">
                <title>Diretrizes Gerais para Comentários</title>
                <guideline>Comentários devem explicar POR QUE, não O QUE</guideline>
                <details>
                    <item>O código deve ser autodocumentado quanto ao QUE ele faz</item>
                    <item>Comentários explicam lógica de negócio, algoritmos complexos ou decisões não óbvias</item>
                </details>
                
                <guideline>Mantenha os comentários atualizados</guideline>
                <details>
                    <item>Atualize comentários quando o código mudar</item>
                    <item>Remova comentários desatualizados</item>
                    <item>Evite comentários redundantes - prefira código autodocumentado</item>
                </details>
            </section>

            <section name="javadoc_standards">
                <title>Padrões JavaDoc</title>
                <coverage>
                    <item>Todas as classes e seus membros</item>
                    <item>Todos os métodos públicos e protegidos</item>
                    <item>Todas as interfaces e enums</item>
                    <item>APIs públicas e endpoints REST</item>
                    <item>DTOs e modelos de domínio importantes</item>
                </coverage>

                <format>
                    <template>
                    /**
                     * Breve descrição do item
                     * 
                     * @param paramName Descrição do parâmetro
                     * @return Descrição do valor de retorno
                     * @throws ExceptionType Descrição de quando esta exceção ocorre
                     */
                    </template>
                </format>

                <supported_tags>
                    <tag>@param</tag>
                    <tag>@return</tag>
                    <tag>@throws</tag>
                    <tag>@exception</tag>
                    <tag>@see</tag>
                    <tag>@link</tag>
                    <tag>@deprecated</tag>
                    <tag>@since</tag>
                    <tag>@author</tag>
                    <tag>@version</tag>
                    <tag>@code</tag>
                    <tag>@implSpec</tag>
                    <tag>@implNote</tag>
                    <tag>@apiNote</tag>
                </supported_tags>

                <tag_rules>
                    <rule>Use primeira letra maiúscula e termine com ponto: @param nome Descrição detalhada.</rule>
                    <rule>Documente todas as exceções que podem ser lançadas</rule>
                    <rule>Inclua exemplos para funcionalidades complexas usando @code</rule>
                    <rule>Use {@link} para referenciar outras classes ou métodos</rule>
                    <rule>Use @implSpec para especificar o contrato de implementação</rule>
                    <rule>Use @apiNote para fornecer recomendações sobre o uso da API</rule>
                </tag_rules>
            </section>

            <section name="spring_quarkus_specific">
                <title>Comentários Específicos para Spring/Quarkus</title>
                
                <subsection name="rest_controllers">
                    <guideline>Documente todos os endpoints REST</guideline>
                    <template>
                    /**
                     * Breve descrição do endpoint
                     * 
                     * @param requestParam Descrição do parâmetro da requisição
                     * @return Descrição do objeto de resposta
                     * @throws ExceptionType Descrição das condições de erro
                     */
                    @GetMapping("/endpoint")
                    public ResponseEntity&lt;ResponseType&gt; endpointMethod(
                        @RequestParam String requestParam) {
                        // Implementação
                    }
                    </template>
                </subsection>
                
                <subsection name="service_layer">
                    <guideline>Documente o propósito e responsabilidades do serviço</guideline>
                    <guideline>Documente regras de negócio complexas</guideline>
                    <template>
                    /**
                     * Serviço responsável por gerenciar operações relacionadas a [domínio].
                     */
                    @Service
                    public class DomainService {
                    
                        /**
                         * Realiza [operação de negócio] e retorna [resultado].
                         *
                         * @param input Dados necessários para a operação
                         * @return Resultado da operação
                         * @throws BusinessException Quando [condição de erro de negócio]
                         */
                        public Output businessOperation(Input input) {
                            // Implementação
                        }
                    }
                    </template>
                </subsection>
                
                <subsection name="repositories">
                    <guideline>Documente queries personalizadas e complexas</guideline>
                    <template>
                    /**
                     * Repositório para acesso a dados da entidade [Entidade].
                     */
                    @Repository
                    public interface EntityRepository extends JpaRepository&lt;Entity, Long&gt; {
                    
                        /**
                         * Busca entidades por [critério específico].
                         *
                         * @param param Parâmetro para filtrar a busca
                         * @return Lista de entidades que atendem ao critério
                         */
                        @Query("SELECT e FROM Entity e WHERE e.property = :param")
                        List&lt;Entity&gt; findByCustomCriteria(@Param("param") String param);
                    }
                    </template>
                </subsection>
                
                <subsection name="dto_models">
                    <guideline>Documente propósito da classe e atributos importantes</guideline>
                    <guideline>Explique regras de validação quando relevante</guideline>
                    <template>
                    /**
                     * DTO que representa [conceito do domínio] para [operação/contexto].
                     */
                    public class DomainDTO {
                    
                        /**
                         * Identificador único.
                         */
                        private Long id;
                        
                        /**
                         * Nome do [entidade]. Não pode ser nulo e deve ter entre 3 e 100 caracteres.
                         */
                        @NotNull
                        @Size(min = 3, max = 100)
                        private String name;
                        
                        // Getters e setters
                    }
                    </template>
                </subsection>
            </section>

            <section name="inline_comments">
                <title>Comentários Inline</title>
                <subsection name="single_line">
                    <guideline>Use // para comentários de linha única</guideline>
                    <guideline>Coloque acima do código que descrevem</guideline>
                    <guideline>Comece com um espaço após //</guideline>
                    <guideline>Use gramática e pontuação apropriadas</guideline>
                </subsection>

                <subsection name="todo">
                    <guideline>Formato: // TODO: (descrição)</guideline>
                    <guideline>Inclua itens de ação específicos</guideline>
                    <guideline>Adicione referência JIRA/issue quando aplicável</guideline>
                </subsection>
                
                <subsection name="block_comments">
                    <guideline>Use /* */ para comentários de múltiplas linhas</guideline>
                    <guideline>Reserve para explicações de algoritmos complexos</guideline>
                    <guideline>Evite blocos grandes de comentários em meio ao código funcional</guideline>
                </subsection>
            </section>

            <section name="examples">
                <title>Exemplos</title>
                <example type="good">
                    <title>Bom JavaDoc</title>
                    <code>
                    /**
                     * Processa dados do usuário de acordo com as regras de negócio especificadas
                     * e retorna o resultado formatado.
                     * 
                     * @param userData Os dados brutos do usuário a serem processados
                     * @param options Opções de configuração para processamento
                     * @return Objeto de dados do usuário formatado
                     * @throws ValidationException Quando os dados do usuário são inválidos
                     * @see UserValidator#validate(UserData)
                     */
                    public FormattedData processUserData(UserData userData, ProcessOptions options) {
                        // Implementação
                    }
                    </code>
                </example>

                <example type="good">
                    <title>Bom JavaDoc para Controller REST</title>
                    <code>
                    /**
                     * Endpoint para criar um novo usuário no sistema.
                     * 
                     * @param userDTO DTO contendo os dados necessários para criar um usuário
                     * @return Objeto DTO com informações do usuário criado
                     * @throws DuplicateResourceException Se já existir um usuário com o mesmo email
                     * @throws ValidationException Se os dados fornecidos forem inválidos
                     */
                    @PostMapping("/users")
                    public ResponseEntity&lt;UserResponseDTO&gt; createUser(@Valid @RequestBody UserCreateDTO userDTO) {
                        // Implementação
                    }
                    </code>
                </example>

                <example type="bad">
                    <title>JavaDoc Ruim</title>
                    <code>
                    // Não faça isso
                    /**
                     * @param userData dados do usuário
                     * @param options opções
                     */
                    public FormattedData processUserData(UserData userData, ProcessOptions options) {
                        // Implementação
                    }
                    </code>
                </example>
                
                <example type="bad">
                    <title>Comentários Desnecessários</title>
                    <code>
                    // Cria um usuário
                    User user = new User();
                    
                    // Define o nome
                    user.setName(name);
                    
                    // Define o email
                    user.setEmail(email);
                    
                    // Salva o usuário
                    userRepository.save(user);
                    </code>
                </example>
            </section>
        </guidelines>

        <metadata>
            <priority>high</priority>
            <version>1.0</version>
        </metadata>
    </rule>
</cursor_rules>