{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types", "./src/mcp"]
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "out",
    "dist"
  ],
  "include": [
    "src/**/*",
    "test/**/*"
  ]
} 